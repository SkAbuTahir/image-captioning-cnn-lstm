{
  "builds": [
    { "src": "api/predict.py", "use": "@vercel/python", "config": { "maxLambdaSize": "50mb", "pythonVersion": "3.11" } },
    { "src": "api/health.py",  "use": "@vercel/python", "config": { "pythonVersion": "3.11" } },
    { "src": "package.json",   "use": "@vercel/next" }
  ],
  "routes": [
    { "src": "/api/predict", "dest": "/api/predict.py" },
    { "src": "/api/health",  "dest": "/api/health.py" },
    { "src": "/(.*)",        "dest": "/$1" }
  ]
}
